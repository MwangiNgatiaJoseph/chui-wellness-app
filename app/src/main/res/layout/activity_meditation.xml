<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:backgroundTint="#07689f"
    android:background="#0440f0"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Meditation">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Meditation"
        android:textColor="#FFFCFC"
        android:backgroundTint="#1FC8C8"
        android:textSize="30dp"
        android:textAlignment="center"
        android:fontFamily="sans-serif-condensed-light"
        android:layout_marginTop="20dp"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/image3"
        android:scaleType="centerCrop"
        android:layout_margin="30dp"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Meditation this is one of the major role in maintaining a healthy body.So remember
to always stay relaxed and let the body do it`s thing.Seat still breath and just let it go"
        android:textAlignment="center"
        android:textColor="#FFFCFC"
        android:textSize="20dp"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Relax!"
        android:layout_margin="30dp"
        android:textSize="30dp"
        android:backgroundTint="#1FC8C8"
        />



</LinearLayout>