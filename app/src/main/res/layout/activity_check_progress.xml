<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:backgroundTint="#07689f"
    android:background="#0440f0"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CheckProgress">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Progress"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#FFFCFC"
        android:backgroundTint="#1FC8C8"
        android:fontFamily="sans-serif-condensed-light"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:layout_margin="30dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image1"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Be awere of every thing your body is doing and feeling.Once body
is like a temple it should be checked on a regular basis,in this case the (THE CHECK PROGRESS PAGE)
where we keep all the progresses you as an individual has made in the past days.
So remember our dear user always be aware of whatever your body is going through.."
        android:textColor="#FFFCFC"
        android:textSize="20dp"
        android:fontFamily="sans-serif-condensed-light"
        android:textAlignment="center"
        />
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Be Aware!!"
        android:layout_margin="30dp"
        android:textSize="30dp"
        android:backgroundTint="#1FC8C8"
        />



</LinearLayout>