<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:backgroundTint="#07689f"
    android:background="#0440f0"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoals">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weeekly Goals"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#FFFCFC"
        android:backgroundTint="#1FC8C8"
        android:fontFamily="sans-serif-condensed-light"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/main2"
        android:scaleType="centerCrop"
        android:layout_margin="30dp"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="What do you aim to archive in a specific week ,here we are able to track yuor
weekly goals and show them to you ,and this goals only pertain healthy wise."
        android:textColor="#FFFCFC"
        android:textSize="20dp"
        android:fontFamily="sans-serif-condensed-light"
        android:textAlignment="center"
        />
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My goals!!"
        android:layout_margin="30dp"
        android:textSize="30dp"
        android:backgroundTint="#1FC8C8"
        />

</LinearLayout>