<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:backgroundTint="#07689f"
    android:background="#0440f0"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Hydration">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hydration"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#FFFCFC"
        android:backgroundTint="#1FC8C8"
        android:fontFamily="sans-serif-condensed-light"
        />

    <ImageView
        android:layout_width="360dp"
        android:layout_height="200dp"
        android:layout_margin="30dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image1"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Water one of the human body`s requirements.Make sure your body is always hydrated,
when the body is hydrated it perform my different and important funtion in the body even once that aren`t
visible to the eye.So remember to keep hydrated.."
    android:textAlignment="center"
    android:textColor="#FFFCFC"
    android:textSize="20dp"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Drink water!"
        android:layout_margin="30dp"
        android:textSize="30dp"
        android:backgroundTint="#1FC8C8"
        />

</LinearLayout>