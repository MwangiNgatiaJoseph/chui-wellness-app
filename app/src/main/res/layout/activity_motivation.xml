<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:backgroundTint="#07689f"
    android:background="#0440f0"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Motivation">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Motivation"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="20dp"
        android:textColor="#FFFCFC"
        android:backgroundTint="#1FC8C8"
        android:fontFamily="sans-serif-condensed-light"
        />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:src="@drawable/main2"
        android:scaleType="centerCrop"
        android:layout_margin="30dp"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remember no one is perfect so whatever kind of body you have ,whether slim,
plus size"
        android:textAlignment="center"
        android:textColor="#FFFCFC"
        android:textSize="20dp"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Love your body"
        android:layout_margin="30dp"
        android:textSize="20dp"
        android:backgroundTint="#1FC8C8"
        />


</LinearLayout>